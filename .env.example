# Seller account (your main Nevermined account)
NVM_API_KEY=sandbox:your-seller-api-key-here
BUILDER_ADDRESS=your-wallet-address-here

# Registered agent + plan
NVM_AGENT_ID=
NVM_PLAN_ID=

# Buyer account (separate Nevermined account for testing)
BUYER_API_KEY=sandbox:your-buyer-api-key-here

# Anthropic (for Claude reasoning layer — optional, fallback narratives used if missing)
ANTHROPIC_API_KEY=

# Server config
PORT=3000
# Public URL of this server — used to register endpoints with Nevermined
# Local:      AGENT_URL=http://localhost:3000
# Production: AGENT_URL=https://tallyfor.ai
AGENT_URL=http://localhost:3000
